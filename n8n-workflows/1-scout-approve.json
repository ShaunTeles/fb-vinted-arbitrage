    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    apifyToken: $env.APIFY_API_KEY,\n    anthropicKey: $env.ANTHROPIC_API_KEY,\n    telegramToken: $env.TELEGRAM_BOT_TOKEN,\n    telegramChatId: $env.TELEGRAM_CHAT_ID\n  }\n}];"
      },
      "id": "get-secrets",
      "name": "Get Secrets",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "jsCode": "// MOCK DATA — replacing Apify scraper for testing\n// Simulates realistic Facebook Marketplace kids clothing listings from Prague\nreturn [\n  {\n    json: {\n      id: \"mock-001\",\n      title: \"Zara Kids zimní bunda vel. 104\",\n      price: 350,\n      description: \"Krásná zimní bunda Zara Kids, velikost 104 (3-4 roky). Velmi dobrý stav, nošena jednu sezónu. Barva modrá.\",\n      url: \"https://www.facebook.com/marketplace/item/mock-001\",\n      images: [\"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3f/Biebrzanski_Park_Narodowy_krowa.jpg/320px-Biebrzanski_Park_Narodowy_krowa.jpg\"],\n      sellerName: \"Jana Novákova\"\n    }\n  },\n  {\n    json: {\n      id: \"mock-002\",\n      title: \"H&M sada oblečení pro miminko 62-68\",\n      price: 200,\n      description: \"Sada 5 kusů oblečení H&M pro miminko, vel. 62-68. Téměř nové, nošeno jen párkrát. Bez skvrn.\",\n      url: \"https://www.facebook.com/marketplace/item/mock-002\",\n      images: [\"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3f/Biebrzanski_Park_Narodowy_krowa.jpg/320px-Biebrzanski_Park_Narodowy_krowa.jpg\"],\n      sellerName: \"Petra Svobodová\"\n    }\n  },\n  {\n    json: {\n      id: \"mock-003\",\n      title: \"Nike tenisky dětské vel. 28\",\n      price: 450,\n      description: \"Originální Nike tenisky pro děti, velikost 28. Nošeny cca 3 měsíce, v dobrém stavu. Podrážka neopotřebovaná.\",\n      url: \"https://www.facebook.com/marketplace/item/mock-003\",\n      images: [\"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3f/Biebrzanski_Park_Narodowy_krowa.jpg/320px-Biebrzanski_Park_Narodowy_krowa.jpg\"],\n      sellerName: \"Martin Dvořák\"\n    }\n  }\n];"
      },
      "id": "mock-listings",
      "name": "Mock FB Listings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 300]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "split-batches",
      "name": "Loop Through Items",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1350, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 256,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"You are an arbitrage scoring assistant. Score this Facebook Marketplace kids' clothing listing for resale on Vinted.cz Czech Republic.\\n\\nTitle: {{ $json.title }}\\nPrice: {{ $json.price }} CZK\\nDescription: {{ $json.description }}\\n\\nScore 1-10 based on:\\n1. Is the FB price competitive/good value for what it is?\\n2. Will this item sell quickly on Vinted at {{ $json.price + 600 }} CZK?\\n\\nFast-selling brands: Zara Kids, H&M, Next, Nike, Adidas, Marks & Spencer, Tommy Hilfiger, Boss Baby, Mayoral, Lego Wear, Reima, Columbia, Petit Bateau\\n\\nRespond ONLY with valid JSON:\\n{\\\"score\\\": <1-10>, \\\"reason\\\": \\\"<one sentence>\\\", \\\"brand\\\": \\\"<brand or unknown>\\\", \\\"condition\\\": \\\"<new/very_good/good/fair>\\\", \\\"size\\\": \\\"<size or unknown>\\\"}\"\n  }]\n}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "x-api-key",
              "value": "={{ $('Get Secrets').first().json.anthropicKey }}"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "options": {}
      },
      "id": "claude-score",
      "name": "Claude Score Item",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1570, 300]
    },
    {
      "parameters": {
        "jsCode": "const inputItem = $input.first();\nconst text = inputItem.json.content[0].text;\nconst parsed = JSON.parse(text);\nreturn [{ json: { ...inputItem.json, ...parsed } }];"
      },
      "id": "parse-claude",
      "name": "Parse Claude Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1790, 300]
    },
    {
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "a1",
              "name": "vintedPrice",
              "value": "={{ $json.price + 600 }}",
              "type": "number"
            },
            {
              "id": "a2",
              "name": "fbId",
              "value": "={{ $json.id }}",
              "type": "string"
            },
            {
              "id": "a3",
              "name": "fbUrl",
              "value": "={{ $json.url }}",
              "type": "string"
            },
            {
              "id": "a4",
              "name": "fbPrice",
              "value": "={{ $json.price }}",
              "type": "number"
            }
          ]
        },
        "options": {
          "includeBinaries": false
        }
      },
      "id": "set-fields",
      "name": "Set Computed Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [2010, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "cond1",
              "leftValue": "={{ $json.score }}",
              "rightValue": 7,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-score",
      "name": "Score >= 7?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2230, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.telegram.org/bot' + $('Get Secrets').first().json.telegramToken + '/sendPhoto' }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"chat_id\": \"{{ $('Get Secrets').first().json.telegramChatId }}\",\n  \"photo\": \"{{ $json.images[0] }}\",\n  \"caption\": \"{{ '🛍 <b>' + $json.title + '</b>\\n\\n💰 FB: <b>' + $json.fbPrice + ' CZK</b> → Vinted: <b>' + $json.vintedPrice + ' CZK</b>\\n⭐ Score: ' + $json.score + '/10\\n📝 ' + $json.reason + '\\n🏷 Brand: ' + $json.brand + '\\n📏 Size: ' + $json.size + '\\n\\n<a href=\\\"' + $json.fbUrl + '\\\">View on Facebook</a>' }}\",\n  \"parse_mode\": \"HTML\",\n  \"reply_markup\": \"{{ JSON.stringify({ inline_keyboard: [[{ text: '✅ Approve', callback_data: 'approve:' + $json.fbId }, { text: '❌ Skip', callback_data: 'skip:' + $json.fbId }]] }) }}\"\n}",
        "options": {}
      },
